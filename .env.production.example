# ─────────────────────────────────────────────────────────
# PRODUCTION ENVIRONMENT  —  copy to .env on the server
# NEVER commit the real .env file to git
# ─────────────────────────────────────────────────────────

ENVIRONMENT=production
DEBUG=false

# PostgreSQL
POSTGRES_DATABASE_URL=postgresql+psycopg2://rag_user:STRONG_PASSWORD_HERE@postgres:5432/rag_db

# OpenSearch (container hostname — do not change)
OPENSEARCH_HOST=http://opensearch:9200
OPENSEARCH__HOST=http://opensearch:9200
OPENSEARCH__INDEX_NAME=arxiv-papers
OPENSEARCH__CHUNK_INDEX_SUFFIX=chunks
OPENSEARCH__MAX_TEXT_SIZE=1000000
OPENSEARCH__VECTOR_DIMENSION=1024
OPENSEARCH__VECTOR_SPACE_TYPE=cosinesimil
OPENSEARCH__RRF_PIPELINE_NAME=hybrid-rrf-pipeline
OPENSEARCH__HYBRID_SEARCH_SIZE_MULTIPLIER=2

# arXiv
ARXIV__MAX_RESULTS=15
ARXIV__BASE_URL=https://export.arxiv.org/api/query
ARXIV__PDF_CACHE_DIR=./data/arxiv_pdfs
ARXIV__RATE_LIMIT_DELAY=3.0
ARXIV__TIMEOUT_SECONDS=30
ARXIV__SEARCH_CATEGORY=cs.AI
ARXIV__DOWNLOAD_MAX_RETRIES=3
ARXIV__DOWNLOAD_RETRY_DELAY_BASE=5.0
ARXIV__MAX_CONCURRENT_DOWNLOADS=5
ARXIV__MAX_CONCURRENT_PARSING=1

# PDF Parser
PDF_PARSER__MAX_PAGES=30
PDF_PARSER__MAX_FILE_SIZE_MB=20
PDF_PARSER__DO_OCR=false
PDF_PARSER__DO_TABLE_STRUCTURE=true

# Chunking
CHUNKING__CHUNK_SIZE=600
CHUNKING__OVERLAP_SIZE=100
CHUNKING__MIN_CHUNK_SIZE=100
CHUNKING__SECTION_BASED=true

# Jina AI Embeddings
JINA_API_KEY=your-production-jina-api-key

# Langfuse (self-hosted — container hostname for app, public URL for browser)
LANGFUSE__ENABLED=true
LANGFUSE__HOST=http://langfuse:3000
LANGFUSE__PUBLIC_KEY=pk-lf-your-production-public-key
LANGFUSE__SECRET_KEY=sk-lf-your-production-secret-key
LANGFUSE__FLUSH_AT=15
LANGFUSE__FLUSH_INTERVAL=1.0
LANGFUSE__DEBUG=false

# Langfuse container secrets — overridden by compose.prod.yml
# NEXTAUTH_URL must be the public URL users/browsers hit
NEXTAUTH_URL=https://your-domain.com:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
LANGFUSE_SALT=generate-with-openssl-rand-base64-32

# LLM Provider
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your-production-llm-api-key
LLM_MODEL=openrouter/free
LLM_TIMEOUT=300
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9

# Telegram Bot (optional)
TELEGRAM__ENABLED=false
TELEGRAM__BOT_TOKEN=your-production-bot-token
TELEGRAM__ALLOWED_USER_IDS=123456789
TELEGRAM__USE_WEBHOOK=false
TELEGRAM__WEBHOOK_URL=
TELEGRAM__WEBHOOK_PATH=/telegram/webhook
TELEGRAM__MAX_MESSAGE_LENGTH=4000
TELEGRAM__SESSION_TIMEOUT_MINUTES=30
TELEGRAM__DEFAULT_TOP_K=3
TELEGRAM__DEFAULT_USE_HYBRID=true
TELEGRAM__USE_AGENTIC=true
# Ingestion push notifications: after the Airflow crawl completes, send a digest
# of newly crawled papers to a fixed chat. Independent of TELEGRAM__ENABLED.
TELEGRAM__NOTIFY_ON_INGESTION=false
TELEGRAM__NOTIFY_CHAT_ID=
TELEGRAM__NOTIFY_MAX_PAPERS=15
TELEGRAM__NOTIFY_ABSTRACT_CHARS=200

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=false
AIRFLOW__HOME=/opt/airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://rag_user:STRONG_PASSWORD_HERE@postgres:5432/rag_db
